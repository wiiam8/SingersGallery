<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/splashIcon"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/wireless_microphone_television_show_united_states_radio_png_removebg_preview"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SINGERS"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:letterSpacing="0.3" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="G A L L E R Y"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.6"
            android:layout_marginBottom="32dp" />

        <View
            android:id="@+id/splashLine"
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#E53935"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Celebrate the music 🎵"
            android:textSize="13sp"
            android:textColor="#666666" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:text="Loading..."
        android:textSize="12sp"
        android:textColor="#444444" />

</FrameLayout>